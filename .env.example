# ============================================================
# CRM FRIGO — Variables de entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Edita .env con tus valores reales
#   3. NUNCA subas .env al repositorio (está en .gitignore)
# ============================================================

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_bd
#
# Desarrollo con Docker (puerto 5433 para no chocar con PostgreSQL local):
DATABASE_URL=postgresql+asyncpg://crmfrigo:crmfrigo123@localhost:5433/hvac_saas
#
# Si tu puerto 5432 está libre:
# DATABASE_URL=postgresql+asyncpg://crmfrigo:crmfrigo123@localhost:5432/hvac_saas
#
# Producción (ejemplo):
# DATABASE_URL=postgresql+asyncpg://usuario:password@tu-servidor.com:5432/hvac_saas

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Clave para firmar los tokens. En producción debe ser larga y aleatoria.
# Generar una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-cambiar-en-produccion

# ── App ───────────────────────────────────────────────────────────────────────
# true  → imprime SQL en consola (útil para depurar)
# false → silencioso (usar en producción)
DEBUG=true
